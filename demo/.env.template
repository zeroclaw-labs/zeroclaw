# ZeroClaw demo env vars — copy this to `demo/.env` and fill in the keys.
# `demo/.env` is gitignored; do not commit it.
#
#     cp demo/.env.template demo/.env
#     $EDITOR demo/.env
#     source demo/.env

# Primary provider — MiniMax M2.7 (international endpoint).
# Get a key at https://www.minimax.io/platform
export MINIMAX_API_KEY=""

# Fallback provider — OpenRouter (also serves minimax/minimax-m2.7).
# Get a key at https://openrouter.ai/keys
# export OPENROUTER_API_KEY=""

# Custom data dir so the demo doesn't touch your normal ~/.zeroclaw install.
export ZEROCLAW_CONFIG_DIR="$(pwd)/demo/data/config"
export ZEROCLAW_WORKSPACE="$(pwd)/demo/data/workspace"

# Tighten the agent loop a bit during the demo.
export RUST_LOG="zeroclaw=info,zeroclaw_hardware=info,esp32_sim=info"
