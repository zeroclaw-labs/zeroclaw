# ZeroClaw ESP32 Smart Room demo — environment variables.
#
# Copy and edit:
#     cp demo/.env.template demo/.env
#     $EDITOR demo/.env
#
# `demo/.env` is gitignored.

# Primary model provider (recommended for this demo).
# MiniMax M2.7 via international endpoint.
export MINIMAX_API_KEY=""

# Optional fallback (OpenRouter also hosts minimax/minimax-m2.7).
# export OPENROUTER_API_KEY=""

# Keep demo data isolated from your normal ZeroClaw install.
export ZEROCLAW_CONFIG_DIR="$(pwd)/demo/data/config"
export ZEROCLAW_WORKSPACE="$(pwd)/demo/data/workspace"

# Focused logging for the demo (simulator + hardware + agent).
export RUST_LOG="zeroclaw=info,zeroclaw_hardware=info,esp32_sim=info"
