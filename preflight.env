# Phase 1.1 Wave 0 preflight outputs.
# Used by Wave 1 + 2 plans. Source this file: `set -a; . preflight.env; set +a`

# RESEARCH.md Open Question 1: andreas2301 namespace type — confirmed by user manually creating fork at https://github.com/andreas2301/osAgent. Treat as user account, no --org flag needed.
ANDREAS2301_NAMESPACE_TYPE=User

# RESEARCH.md Open Question 2: Upstream zeroclaw v0.7.5 phone-home deps present?
# Workspace-wide grep for sentry/posthog/honeycomb/datadog/opentelemetry-otlp returned ONE match:
#   crates/zeroclaw-runtime/Cargo.toml has optional opentelemetry-otlp behind feature observability-otel
# The feature is NOT in workspace defaults. With cargo-deny `all-features = false` (which we set),
# the optional dep is not resolved and bans won't trip.
UPSTREAM_HAS_OPTIONAL_OTLP=true
UPSTREAM_HAS_REQUIRED_PHONE_HOME=false

# RESEARCH.md Open Question 3: gh CLI version — gh is not installed on this host. We use raw git
# (credential helper auth) for local push/fetch; user-driven GitHub UI clicks for fork creation
# and PR opening; curl + Authorization header for branch protection (deferred or manual).
GH_INSTALLED=false

# RESEARCH.md Open Question 4: cargo-deny version — not yet installed. Wave 2 task installs via
# `cargo install cargo-deny --locked --version ^0.19`. Once installed, validate-full.sh exercises
# it on every run.
CARGO_DENY_INSTALLED=false

# Tooling actually available on the host:
HOST_HAS_GIT=true
HOST_HAS_CURL=true
HOST_HAS_PYTHON=true
HOST_HAS_JQ=false   # use python -m json.tool for JSON

# Upstream fork point:
UPSTREAM_REPO=zeroclaw-labs/zeroclaw
UPSTREAM_TAG=v0.7.5
UPSTREAM_SHA=a2988f0dfffa0c14fa56e218c7bb9f28da494da4
FORK_DEST=andreas2301/osAgent
FORK_DATE=2026-06-12
