# ZeroClaw Environment Variables
# Copy this file to `.env` and fill in your local values.
# Never commit `.env` or any real secrets.

# ── Core Runtime ──────────────────────────────────────────────
# Provider key resolution at runtime:
# 1) explicit key passed from config/CLI
# 2) provider-specific env var (OPENROUTER_API_KEY, OPENAI_API_KEY, ...)
# 3) generic fallback env vars below

# Generic fallback API key (used when provider-specific key is absent)
API_KEY=your-api-key-here
# ZEROCLAW_API_KEY=your-api-key-here

# Default provider/model (can be overridden by CLI flags)
PROVIDER=openrouter
# ZEROCLAW_PROVIDER=openrouter
# ZEROCLAW_MODEL=anthropic/claude-sonnet-4-6
# ZEROCLAW_TEMPERATURE=0.7

# Workspace directory override
# ZEROCLAW_WORKSPACE=/path/to/workspace

# Reasoning mode (enables extended thinking for supported models)
# ZEROCLAW_REASONING_ENABLED=false
# REASONING_ENABLED=false

# ── Provider-Specific API Keys ────────────────────────────────
# OpenRouter
# OPENROUTER_API_KEY=sk-or-v1-...

# Anthropic
# ANTHROPIC_OAUTH_TOKEN=...
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI / Gemini
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# GOOGLE_API_KEY=...

# Other supported providers
# VENICE_API_KEY=...
# GROQ_API_KEY=...
# MISTRAL_API_KEY=...
# DEEPSEEK_API_KEY=...
# XAI_API_KEY=...
# TOGETHER_API_KEY=...
# FIREWORKS_API_KEY=...
# PERPLEXITY_API_KEY=...
# COHERE_API_KEY=...
# MOONSHOT_API_KEY=...
# GLM_API_KEY=...
# MINIMAX_OAUTH_TOKEN=...
# MINIMAX_API_KEY=...
# MINIMAX_OAUTH_REFRESH_TOKEN=...
# MINIMAX_OAUTH_REGION=global   # optional: global|cn
# QIANFAN_API_KEY=...
# DASHSCOPE_API_KEY=...
# ZAI_API_KEY=...
# SYNTHETIC_API_KEY=...
# OPENCODE_API_KEY=...
# VERCEL_API_KEY=...
# CLOUDFLARE_API_KEY=...

# ── Gateway ──────────────────────────────────────────────────
# ZEROCLAW_GATEWAY_PORT=3000
# ZEROCLAW_GATEWAY_HOST=127.0.0.1
# ZEROCLAW_ALLOW_PUBLIC_BIND=false

# ── Storage ─────────────────────────────────────────────────
# Backend override for persistent storage (default: sqlite)
# ZEROCLAW_STORAGE_PROVIDER=sqlite
# ZEROCLAW_STORAGE_DB_URL=postgres://localhost/zeroclaw
# ZEROCLAW_STORAGE_CONNECT_TIMEOUT_SECS=5

# ── Supabase (Cloud User Management + Credits) ──────────────
# When configured, user accounts, credits, usage, and audit logs
# are stored in Supabase. Local SQLite auth remains as fallback.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIs...
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...   (optional, for client-side RLS)

# ── Proxy ──────────────────────────────────────────────────
# Forward provider/service traffic through an HTTP(S) proxy.
# ZEROCLAW_PROXY_ENABLED=false
# ZEROCLAW_HTTP_PROXY=http://proxy.example.com:8080
# ZEROCLAW_HTTPS_PROXY=http://proxy.example.com:8080
# ZEROCLAW_ALL_PROXY=socks5://proxy.example.com:1080
# ZEROCLAW_NO_PROXY=localhost,127.0.0.1
# ZEROCLAW_PROXY_SCOPE=zeroclaw          # environment|zeroclaw|services
# ZEROCLAW_PROXY_SERVICES=openai,anthropic

# ── Optional Integrations ────────────────────────────────────
# Pushover notifications (`pushover` tool)
# PUSHOVER_TOKEN=your-pushover-app-token
# PUSHOVER_USER_KEY=your-pushover-user-key

# ── Channel Tokens (Optional — enable as needed) ─────────────
# Set the primary token env var to activate each channel.
# ALLOWED_USERS: comma-separated user IDs, or "*" to allow all.
#
# ZEROCLAW_TELEGRAM_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# ZEROCLAW_TELEGRAM_ALLOWED_USERS=*
#
# ZEROCLAW_DISCORD_TOKEN=your_discord_bot_token
# ZEROCLAW_DISCORD_ALLOWED_USERS=*
#
# ZEROCLAW_SLACK_TOKEN=xoxb-your-slack-bot-token
# ZEROCLAW_SLACK_APP_TOKEN=xapp-your-slack-app-token
# ZEROCLAW_SLACK_ALLOWED_USERS=*
#
# ZEROCLAW_WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
# ZEROCLAW_WHATSAPP_PHONE_NUMBER_ID=123456789
# ZEROCLAW_WHATSAPP_VERIFY_TOKEN=your_verify_token
# ZEROCLAW_WHATSAPP_ALLOWED_NUMBERS=*
#
# ZEROCLAW_LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
# ZEROCLAW_LINE_CHANNEL_SECRET=your_line_channel_secret
# ZEROCLAW_LINE_ALLOWED_USERS=*
#
# ZEROCLAW_KAKAO_REST_API_KEY=your_kakao_rest_api_key
# ZEROCLAW_KAKAO_ADMIN_KEY=your_kakao_admin_key
# ZEROCLAW_KAKAO_ALLOWED_USERS=*
#
# ZEROCLAW_LARK_APP_ID=cli_your_app_id
# ZEROCLAW_LARK_APP_SECRET=your_lark_app_secret
# ZEROCLAW_LARK_ALLOWED_USERS=*
#
# ZEROCLAW_DINGTALK_CLIENT_ID=your_dingtalk_client_id
# ZEROCLAW_DINGTALK_CLIENT_SECRET=your_dingtalk_client_secret
# ZEROCLAW_DINGTALK_ALLOWED_USERS=*
#
# ZEROCLAW_QQ_APP_ID=your_qq_app_id
# ZEROCLAW_QQ_APP_SECRET=your_qq_app_secret
# ZEROCLAW_QQ_ALLOWED_USERS=*
#
# ZEROCLAW_MATRIX_ACCESS_TOKEN=your_matrix_access_token
# ZEROCLAW_MATRIX_HOMESERVER=https://matrix.org
# ZEROCLAW_MATRIX_ROOM_ID=!room_id:matrix.org
# ZEROCLAW_MATRIX_ALLOWED_USERS=@user:matrix.org
#
# ZEROCLAW_SIGNAL_HTTP_URL=http://localhost:8080
# ZEROCLAW_SIGNAL_ACCOUNT=+1234567890
# ZEROCLAW_SIGNAL_ALLOWED_FROM=+1234567890

# ── Docker Compose ───────────────────────────────────────────
# Host port mapping (used by docker-compose.yml)
# HOST_PORT=3000

# ── Z.AI GLM Coding Plan ───────────────────────────────────────
# Z.AI provides GLM models through OpenAI-compatible endpoints.
# API key format: id.secret (e.g., abc123.xyz789)
#
# Usage:
#   zeroclaw onboard --provider zai --api-key YOUR_ZAI_API_KEY
#
# Or set the environment variable:
# ZAI_API_KEY=your-id.secret
#
# Common models: glm-5, glm-4.7, glm-4-plus, glm-4-flash
# See docs/zai-glm-setup.md for detailed configuration.

# ── Model Routing (Tiered Multi-Model) ────────────────────────
# Route different task types to different provider/model combos.
# Pattern: ZEROCLAW_ROUTE_<HINT>_PROVIDER / ZEROCLAW_ROUTE_<HINT>_MODEL
#
# === Auto-routing behavior ===
#
# Tier 1 (daily) is ALWAYS injected (online mode):
#   - Uses gemini-3.1-flash-lite-preview for initial routing, scheduling, Q&A.
#   - Offline mode falls back to local SLM (e.g. ollama/llama3.2).
#
# When NO provider-specific API key is set:
#   - Platform-default tiered routes are injected:
#     Tier 2 (document) → gemini-3.1-pro-preview
#     Tier 3 (code)     → claude-4.6-opus
#     Tier 4 (review)   → gpt-5.4
#
# When a provider-specific API key IS set (e.g. ANTHROPIC_API_KEY):
#   - The user chose that provider; routes use the provider's best models:
#     fast (chat/document) → provider's fastest top model
#     reasoning (code)     → provider's best thinking model
#   - Cost is on the user, so maximum quality models are used.
#
# === Explicit overrides (always take precedence) ===
#
# ZEROCLAW_ROUTE_DAILY_PROVIDER=google
# ZEROCLAW_ROUTE_DAILY_MODEL=gemini-3.1-flash-lite-preview
#
# ZEROCLAW_ROUTE_DOCUMENT_PROVIDER=google
# ZEROCLAW_ROUTE_DOCUMENT_MODEL=gemini-3.1-pro-preview
#
# ZEROCLAW_ROUTE_CODE_PROVIDER=anthropic
# ZEROCLAW_ROUTE_CODE_MODEL=claude-4.6-opus
#
# ZEROCLAW_ROUTE_REVIEW_PROVIDER=openai
# ZEROCLAW_ROUTE_REVIEW_MODEL=gpt-5.4
#
# Optional per-route overrides:
# ZEROCLAW_ROUTE_CODE_MAX_TOKENS=8192
# ZEROCLAW_ROUTE_CODE_API_KEY=sk-...
#
# Enable automatic query classification (routes messages by content):
# ZEROCLAW_QUERY_CLASSIFICATION_ENABLED=true
#
# Set default model to use the daily hint for cost savings:
# ZEROCLAW_MODEL=hint:daily

# ── Web Search ────────────────────────────────────────────────
# Web search tool for finding information on the internet.
# Enabled by default with DuckDuckGo (free, no API key required).
#
# WEB_SEARCH_ENABLED=true
# WEB_SEARCH_PROVIDER=duckduckgo
# WEB_SEARCH_MAX_RESULTS=5
# WEB_SEARCH_TIMEOUT_SECS=15
#
# Optional: Brave Search (requires API key from https://brave.com/search/api)
# WEB_SEARCH_PROVIDER=brave
# BRAVE_API_KEY=your-brave-search-api-key
