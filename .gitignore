# Document skills: only include the 5 core skills (docx, pdf, xlsx, pptx, hwpx)
# Law-specific skills are excluded from the general MoA app
.claude/skills/document_skills/*
!.claude/skills/document_skills/docx/
!.claude/skills/document_skills/pdf/
!.claude/skills/document_skills/xlsx/
!.claude/skills/document_skills/pptx/
!.claude/skills/document_skills/hwpx/
