{
  "version": "0.2.0",
  "inputs": [
    {
      "id": "testName",
      "description": "Exact test name to debug (e.g. tests::my_test)",
      "type": "promptString",
      "default": ""
    }
  ],
  "configurations": [
    // ── Runtime ───────────────────────────────────────────
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug: Agent",
      "cargo": {
        "args": ["build"],
        "filter": {
          "name": "zeroclaw",
          "kind": "bin"
        }
      },
      "args": ["agent"],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug: Gateway",
      "cargo": {
        "args": ["build"],
        "filter": {
          "name": "zeroclaw",
          "kind": "bin"
        }
      },
      "args": ["gateway"],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug: Daemon",
      "cargo": {
        "args": ["build"],
        "filter": {
          "name": "zeroclaw",
          "kind": "bin"
        }
      },
      "args": ["daemon"],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug: Status",
      "cargo": {
        "args": ["build"],
        "filter": {
          "name": "zeroclaw",
          "kind": "bin"
        }
      },
      "args": ["status"],
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug: Onboard",
      "cargo": {
        "args": ["build"],
        "filter": {
          "name": "zeroclaw",
          "kind": "bin"
        }
      },
      "args": ["onboard"],
      "cwd": "${workspaceFolder}"
    },
    // ── Test ──────────────────────────────────────────────
    {
      "type": "lldb",
      "request": "launch",
      "name": "Debug: Test (by name)",
      "cargo": {
        "args": ["test", "--no-run", "--lib", "--"],
        "filter": {
          "kind": "lib"
        }
      },
      "args": ["--exact", "${input:testName}", "--nocapture"],
      "cwd": "${workspaceFolder}"
    }
  ]
}
