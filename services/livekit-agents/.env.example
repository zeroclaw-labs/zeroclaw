# ── LiveKit Server ──
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxx

# ── STT: Deepgram Nova-3 ──
DEEPGRAM_API_KEY=dg_xxxxxxxxxxxxxxxx

# ── TTS: Typecast (전용 TTS provider) ──
# API docs: https://typecast.ai/docs/api-reference/text-to-speech
# Voices: GET https://api.typecast.ai/v2/voices (X-API-KEY header)
# Auth: X-API-KEY header
# Endpoint: POST https://api.typecast.ai/v1/text-to-speech
# Response: binary WAV/MP3 (synchronous, no polling)
TYPECAST_API_KEY=tc_xxxxxxxxxxxxxxxx
TYPECAST_VOICE_ID_KO_FEMALE=tc_672c5f5ce59fac2a48faeaee

# ── LLM: operator fallback keys ──
GOOGLE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Gemini Live S2S (dev/test only) ──
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_LIVE_VOICE=Puck

# ── moa gateway (for billing hook) ──
MOA_GATEWAY_URL=http://127.0.0.1:8080
