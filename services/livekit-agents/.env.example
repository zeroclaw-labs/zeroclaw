# -----------------------------------------------------------------------------
# moa 음성 대화 서비스 — 환경변수 템플릿
#
# 사용법:
#   1) 이 파일을 .env 로 복사
#   2) 아래 값을 실제 키로 채움
#   3) python agent_pipeline.py dev  (또는 start)
# -----------------------------------------------------------------------------

# === LiveKit Cloud 또는 자체 호스팅 서버 ===
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=LK-your-api-key
LIVEKIT_API_SECRET=your-secret

# === STT (Deepgram Nova-3, 필수) ===
DEEPGRAM_API_KEY=your-deepgram-key

# === TTS (Cartesia Sonic-3, 필수) ===
CARTESIA_API_KEY=your-cartesia-key
# Cartesia 보이스 ID (Cartesia 대시보드에서 확인 후 교체)
CARTESIA_VOICE_ID_DEFAULT=f786b574-daa5-4673-aa0c-cbe3e8534c02

# === TTS (Typecast 프리미엄 한국어, 선택) ===
# 등록: https://typecast.ai 무료 30k 크레딧/월
TYPECAST_API_KEY=
TYPECAST_VOICE_ID_KO_FEMALE=
TYPECAST_VOICE_ID_KO_MALE=

# === LLM — 운영자 기본 키 (이용자가 본인 키를 넣지 않았을 때 fallback) ===
# 운영자 기본: Gemini 3.1 Flash
GOOGLE_API_KEY=your-gemini-key
# 선택: Claude 계열 운영자 기본
ANTHROPIC_API_KEY=
# 선택: OpenAI 운영자 기본
OPENAI_API_KEY=

# === S2S 모드용 (Gemini Live API) ===
# ⚠️ 현재 preview — 프로덕션 사용 금지. 개발·테스트에만.
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_LIVE_VOICE=Puck

# === Naver CLOVA (선택, 한국어 법률 도메인 백업 STT) ===
NCP_CLOVASPEECH_INVOKE_URL=
NCP_CLOVASPEECH_SECRET=
