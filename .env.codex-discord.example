# ZeroClaw dev container env for OpenAI Codex subscription auth + Discord
# Copy to `.env` and fill required values.

# Required: Discord bot token from Discord Developer Portal
DISCORD_BOT_TOKEN=replace-with-your-discord-bot-token

# Optional: Discord behavior
# true = bot replies only when explicitly @mentioned
# false = bot can reply to normal messages in channels it can read
DISCORD_MENTION_ONLY=false

# Optional: process messages sent by other bots
DISCORD_LISTEN_TO_BOTS=false

# Optional: verbose logs (recommended while debugging)
# Example focuses on Discord + channel runtime + OpenAI Codex provider internals.
RUST_LOG=debug,zeroclaw=trace,zeroclaw::channels::discord=trace,zeroclaw::channels=trace,zeroclaw::providers::openai_codex=trace,zeroclaw::providers::reliable=debug

# Optional: cargo features used by in-container `zeroclaw` wrapper.
# Keep `rag-pdf` enabled to extract text from PDF attachments.
ZEROCLAW_CARGO_FEATURES=rag-pdf

# Optional: observability backend for generated config.toml
# options: none | noop | log | prometheus | otel | opentelemetry | otlp
ZEROCLAW_OBSERVABILITY_BACKEND=log
# Used only when backend is otel/opentelemetry/otlp
ZEROCLAW_OTEL_ENDPOINT=http://localhost:4318
ZEROCLAW_OTEL_SERVICE_NAME=zeroclaw-dev-codex-discord

# Optional: runtime trace file (includes turn/tool/provider events)
# mode: none | rolling | full
ZEROCLAW_RUNTIME_TRACE_MODE=rolling
ZEROCLAW_RUNTIME_TRACE_PATH=state/runtime-trace.jsonl
ZEROCLAW_RUNTIME_TRACE_MAX_ENTRIES=2000

# Optional: add diagnostics shell commands to allowed_commands
# false = keep shell allowlist minimal (+curl)
# true  = also allow `env` and `printenv`
ZEROCLAW_ALLOW_DIAGNOSTIC_SHELL_COMMANDS=false

# Optional: Facebook Page posting tool (`facebook_page_post`)
# ZEROCLAW_FB_APP_ID=your-facebook-app-id
# ZEROCLAW_FB_APP_SECRET=your-facebook-app-secret
# ZEROCLAW_FB_PAGE_ID=your-facebook-page-id
# ZEROCLAW_FB_ACCESS_TOKEN=your-facebook-page-access-token
# Optional API base override
# FACEBOOK_GRAPH_API_BASE=https://graph.facebook.com/v22.0
