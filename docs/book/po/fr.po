msgstr ""
"`zeroclaw_bot`, `zeroclaw_service`, `zeroclaw_runtime`, `zeroclaw_node`"

#: src/contributing/privacy.md:26
msgid "Environment labels"
msgstr "Étiquettes d'environnement"

#: src/contributing/privacy.md:26
