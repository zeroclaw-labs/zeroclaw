"`--level <LEVEL>` — Level used when engaging estop from `zeroclaw estop`"
msgstr ""
"`--level <LEVEL>` — Niveau utilisé lors de l'activation de l'arrêt d'urgence "
"via `zeroclaw estop`"

#: src/reference/cli.md:478
msgid ""
"Possible values: `kill-all`, `network-kill`, `domain-block`, `tool-freeze`"
msgstr ""
"Valeurs possibles : `kill-all`, `network-kill`, `domain-block`, `tool-freeze`"

#: src/reference/cli.md:480
msgid ""
"`--domain <DOMAINS>` — Domain pattern(s) for `domain-block` (repeatable)"
msgstr ""
"`--domain <DOMAINS>` — Motif(s) de domaine pour `domain-block` (répétable)"

#: src/reference/cli.md:481
msgid "`--tool <TOOLS>` — Tool name(s) for `tool-freeze` (repeatable)"
msgstr "`--tool <OUTILS>` — Nom(s) de l'outil pour `tool-freeze` (répétable)"

#: src/reference/cli.md:485
msgid "`zeroclaw estop status`"
msgstr "`zeroclaw estop status`"

#: src/reference/cli.md:487
msgid "Print current estop status"
msgstr "Afficher l'état actuel de l'arrêt d'urgence"

#: src/reference/cli.md:489
msgid "**Usage:** `zeroclaw estop status`"
msgstr "**Utilisation :** `zeroclaw estop status`"

#: src/reference/cli.md:493
msgid "`zeroclaw estop resume`"
msgstr "`zeroclaw estop resume`"

#: src/reference/cli.md:495
msgid "Resume from an engaged estop level"
msgstr "Reprendre depuis un niveau d'arrêt d'urgence activé"

#: src/reference/cli.md:497
msgid "**Usage:** `zeroclaw estop resume [OPTIONS]`"
msgstr "**Utilisation :** `zeroclaw estop resume [OPTIONS]`"

#: src/reference/cli.md:501
msgid "`--network` — Resume only network kill"
msgstr "`--network` — Reprendre uniquement la suppression du réseau"

#: src/reference/cli.md:502
msgid "`--domain <DOMAINS>` — Resume one or more blocked domain patterns"
msgstr ""
"`--domain <DOMAINS>` — Reprendre un ou plusieurs motifs de domaines bloqués"

#: src/reference/cli.md:503
msgid "`--tool <TOOLS>` — Resume one or more frozen tools"
msgstr "`--tool <OUTILS>` — Reprendre un ou plusieurs outils gelés"

#: src/reference/cli.md:504
