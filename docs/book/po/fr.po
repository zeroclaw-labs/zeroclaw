msgstr "# ou `zeroclaw daemon` pour exécuter en premier plan\n"

#: src/channels/matrix.md:66
msgid "Send a plain-text message in the configured Matrix room. Confirm:"
msgstr ""
"Envoyer un message en texte brut dans la salle Matrix configurée. Confirmer :"

