msgstr "Paramètres spécifiques à chaque fournisseur"

#: src/providers/configuration.md:78
msgid "Beyond the universal fields, some providers accept extras. Highlights:"
msgstr ""
"Au-delà des champs universels, certains fournisseurs acceptent des champs "
"supplémentaires. Points saillants :"

#: src/providers/configuration.md:80 src/providers/catalog.md:33
msgid "Ollama"
msgstr "Ollama"

#: src/providers/configuration.md:82
msgid ""
"```toml\n"
"[providers.models.local]\n"
"kind = \"ollama\"\n"
"base_url = \"http://localhost:11434\"\n"
"model = \"qwen3.6:35b-a3b\"\n"
"think = false                # disable reasoning mode for faster output\n"
"reasoning_effort = \"none\"    # same intent, passed as a top-level field\n"
"options = { temperature = 0, num_ctx = 32768 }\n"
"```"
msgstr ""
"```toml\n"
"[providers.models.local]\n"
"kind = \"ollama\"\n"
"base_url = \"http://localhost:11434\"\n"
"model = \"qwen3.6:35b-a3b\"\n"
"think = false                # désactiver le mode de raisonnement pour une "
"sortie plus rapide\n"
"reasoning_effort = \"none\"    # même intention, passé en tant que champ de "
"niveau supérieur\n"
"options = { temperature = 0, num_ctx = 32768 }\n"
"```"

#: src/providers/configuration.md:92
msgid "OpenAI-compatible"
msgstr "Compatible avec OpenAI"

#: src/providers/configuration.md:94
msgid ""
"```toml\n"
"[providers.models.groq]\n"
"kind = \"openai-compatible\"\n"
"base_url = \"https://api.groq.com/openai\"\n"
"model = \"llama-3.3-70b-versatile\"\n"
"api_key = \"gsk_...\"\n"
"# Optional — supplies SSE tool-call streaming hints the endpoint "
"understands\n"
"native_tool_streaming = true\n"
"```"
msgstr ""
"```toml\n"
"[providers.models.groq]\n"
"kind = \"openai-compatible\"\n"
"base_url = \"https://api.groq.com/openai\"\n"
"model = \"llama-3.3-70b-versatile\"\n"
"api_key = \"gsk_...\"\n"
"# Facultatif — fournit des indications de streaming d'appels d'outils SSE "
"que le point de terminaison comprend\n"
"native_tool_streaming = true\n"
"```"

