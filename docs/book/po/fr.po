msgstr "Composant"

#: src/channels/voice.md:95
msgid "Typical latency"
msgstr "Latence typique"

#: src/channels/voice.md:97
msgid "Wake detection (local)"
msgstr "Détection de réveil (local)"

#: src/channels/voice.md:97
msgid "\\<100 ms"
msgstr "\\<100 ms"

#: src/channels/voice.md:98
msgid "STT (Whisper local)"
msgstr "STT (Whisper local)"

#: src/channels/voice.md:98
msgid "300–800 ms per utterance"
msgstr "300–800 ms par énoncé"

#: src/channels/voice.md:99
msgid "LLM first-token"
msgstr "Premier jeton LLM"

#: src/channels/voice.md:99
msgid "100–2000 ms (model dependent)"
msgstr "100–2000 ms (dépendant du modèle)"

#: src/channels/voice.md:100
