"Ce document définit le protocole entre l'hôte de plugins de ZeroClaw et les "
"modules de plugins WASM."

#: src/developing/plugin-protocol.md:15
msgid "Plugin structure"
msgstr "Structure du plugin"

#: src/developing/plugin-protocol.md:17
msgid "A plugin is a directory containing:"
msgstr "Un plugin est un répertoire contenant :"

#: src/developing/plugin-protocol.md:25
msgid ""
"Plugins are discovered from `~/.zeroclaw/plugins/` (configurable via "
"`plugins.plugins_dir` in config)."
msgstr ""
"Les plugins sont découverts dans `~/.zeroclaw/plugins/` (configurable via "
"`plugins.plugins_dir` dans la configuration)."

#: src/developing/plugin-protocol.md:28
msgid "Manifest format"
msgstr "Format du manifeste"

#: src/developing/plugin-protocol.md:30
msgid ""
"```toml\n"
"name = \"my-plugin\"                    # Unique identifier (required)\n"
"version = \"0.1.0\"                     # Semver version (required)\n"
"description = \"What this plugin does\" # Human-readable (optional)\n"
"author = \"Your Name\"                  # Author (optional)\n"
"wasm_path = \"plugin.wasm\"             # Path to .wasm relative to manifest "
"(required)\n"
"capabilities = [\"tool\"]               # What the plugin provides "
"(required)\n"
"permissions = [\"http_client\"]          # What the plugin needs (optional)\n"
"signature = \"base64url...\"            # Ed25519 signature (optional)\n"
"publisher_key = \"hex...\"              # Publisher public key (optional)\n"
"```"
msgstr ""
"```toml\n"
"name = \"my-plugin\"                    # Identifiant unique (obligatoire)\n"
"version = \"0.1.0\"                     # Version Semver (obligatoire)\n"
"description = \"Ce que fait ce plugin\" # Lisible par un humain (optionnel)\n"
"author = \"Votre Nom\"                  # Auteur (optionnel)\n"
"wasm_path = \"plugin.wasm\"             # Chemin vers le fichier .wasm "
"relatif au manifeste (obligatoire)\n"
"capabilities = [\"tool\"]               # Ce que le plugin fournit "
"(obligatoire)\n"
"permissions = [\"http_client\"]         # Ce dont le plugin a besoin "
"(optionnel)\n"
"signature = \"base64url...\"            # Signature Ed25519 (optionnel)\n"
"publisher_key = \"hex...\"              # Clé publique de l'éditeur "
"(optionnel)\n"
"```"

