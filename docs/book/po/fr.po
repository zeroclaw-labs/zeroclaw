msgstr "`--session <SESSION>`"

#: src/reference/cli.md:1423
msgid "`--limit <LIMIT>`"
msgstr "`--limit <LIMIT>`"

#: src/reference/cli.md:1426
msgid "`--offset <OFFSET>`"
msgstr "`--offset <OFFSET>`"

#: src/reference/cli.md:1428
