#: src/foundations/fnd-001-intentional-architecture.md
msgid "Write an OpenAPI 3.1 spec for the kernel's local IPC API before implementing it"
msgstr ""
"```yaml\n"
"openapi: 3.1.0\n"
"info:\n"
"  title: Kernel Local IPC API\n"
"  version: 1.0.0\n"
"  description: >\n"
"    This specification defines the local Inter-Process Communication (IPC) API\n"
"    for the kernel. It allows processes to exchange messages and synchronize\n"
"    operations within the same system.\n"
"servers:\n"
"  - url: /api/v1/ipc\n"
"    description: Local IPC endpoint\n"
"paths:\n"
"  /send:\n"
"    post:\n"
"      summary: Send a message to another process\n"
"      operationId: sendMessage\n"
"      requestBody:\n"
"        required: true\n"
"        content:\n"
"          application/json:\n"
"            schema:\n"
"              $ref: '#/components/schemas/Message'\n"
"      responses:\n"
"        '200':\n"
"          description: Message sent successfully\n"
"          content:\n"
"            application/json:\n"
"              schema:\n"
"                $ref: '#/components/schemas/Response'\n"
"        '400':\n"
"          description: Invalid request\n"
"        '500':\n"
"          description: Internal server error\n"
"  /receive:\n"
"    get:\n"
"      summary: Receive a message from another process\n"
"      operationId: receiveMessage\n"
"      parameters:\n"
"        - name: timeout\n"
"          in: query\n"
"          required: false\n"
"          schema:\n"
"            type: integer\n"
"            description: Timeout in milliseconds\n"
"      responses:\n"
"        '200':\n"
"          description: Message received successfully\n"
"          content:\n"
"            application/json:\n"
"              schema:\n"
"                $ref: '#/components/schemas/Message'\n"
"        '408':\n"
"          description: Request timeout\n"
"        '500':\n"
"          description: Internal server error\n"
"components:\n"
"  schemas:\n"
"    Message:\n"
"      type: object\n"
"      properties:\n"
"        sender:\n"
"          type: string\n"
"          description: Sender process ID\n"
"        receiver:\n"
"          type: string\n"
"          description: Receiver process ID\n"
"        payload:\n"
"          type: string\n"
"          description: Message content\n"
"        timestamp:\n"
"          type: string\n"
"          format: date-time\n"
"          description: Message timestamp\n"
"    Response:\n"
"      type: object\n"
"      properties:\n"
"        status:\n"
"          type: string\n"
"          description: Operation status\n"
"        message:\n"
"          type: string\n"
"          description: Response message\n"
"```"

