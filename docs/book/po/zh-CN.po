msgstr "```toml\n[sop]\nname = \"deploy-prod\"\ndescription = \"手动部署，需明确审批\"\nversion = \"1.0.0\"\npriority = \"high\"\nexecution_mode = \"supervised\"\nmax_concurrent = 1\n\n[[triggers]]\ntype = \"manual\"\n```"

#: src/sop/cookbook.md:22 src/sop/cookbook.md:53 src/sop/cookbook.md:82
