#: src/channels/overview.md:25 src/channels/overview.md:36
#: src/channels/overview.md:45 src/channels/overview.md:56
msgid "Channel"
msgstr "通道"

#: src/providers/streaming.md:43
msgid "Draft updates"
msgstr "草稿更新"

#: src/providers/streaming.md:43
msgid "Multi-message"
msgstr "多消息"

#: src/providers/streaming.md:45 src/providers/streaming.md:46
#: src/providers/streaming.md:47 src/providers/streaming.md:48
