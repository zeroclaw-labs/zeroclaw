msgstr "2. IoT 告警处理器 (MQTT)"

#: src/sop/cookbook.md:39
msgid ""
"```toml\n"
"[sop]\n"
"name = \"high-temp-alert\"\n"
"description = \"Handle high temperature telemetry alerts\"\n"
"version = \"1.0.0\"\n"
"priority = \"critical\"\n"
"execution_mode = \"priority_based\"\n"
"\n"
"[[triggers]]\n"
"type = \"mqtt\"\n"
"topic = \"sensors/temp/alert\"\n"
"condition = \"$.temperature_c >= 85\"\n"
