msgid "`provider-<name>` — opt-in per provider"
msgstr "`provider-<name>` — 按提供商选择加入"

#: src/architecture/crates.md:134
msgid "`hardware` — enable hardware subsystem"
msgstr "`hardware` — 启用硬件子系统"

#: src/architecture/crates.md:135
msgid "`tui` — terminal UI"
msgstr "`tui` — 终端用户界面"

#: src/architecture/crates.md:137
