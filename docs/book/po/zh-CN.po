#: src/reference/cli.md:1492
msgid "**Subcommands:**"
msgstr "**子命令：**"

#: src/reference/cli.md:114
msgid "`onboard` — Initialize your workspace and configuration"
msgstr "`onboard` — 初始化您的工作区和配置"

#: src/reference/cli.md:115
msgid "`agent` — Start the AI agent loop"
msgstr "`agent` — 启动 AI 代理循环"

#: src/reference/cli.md:116
msgid "`gateway` — Start/manage the gateway server (webhooks, websockets)"
msgstr "`gateway` — 启动/管理网关服务器（webhooks、websockets）"

#: src/reference/cli.md:117
msgid "`acp` — Start ACP (Agent Control Protocol) server over stdio"
msgstr "`acp` — 通过 stdio 启动 ACP（Agent Control Protocol）服务器"

#: src/reference/cli.md:118
msgid ""
"`daemon` — Start long-running autonomous runtime (gateway + channels + "
"heartbeat + scheduler)"
msgstr "`daemon` — 启动长期运行的自主运行时（网关 + 通道 + 心跳 + 调度器）"

#: src/reference/cli.md:119
msgid "`service` — Manage OS service lifecycle (launchd/systemd user service)"
msgstr "`service` — 管理操作系统服务生命周期（launchd/systemd 用户服务）"

#: src/reference/cli.md:120
msgid "`doctor` — Run diagnostics for daemon/scheduler/channel freshness"
msgstr "`doctor` — 运行守护进程/调度器/通道新鲜度的诊断"

#: src/reference/cli.md:121
msgid "`status` — Show system status (full details)"
msgstr "`status` — 显示系统状态（详细信息）"

#: src/reference/cli.md:122
msgid "`estop` — Engage, inspect, and resume emergency-stop states"
msgstr "`estop` — 启用、检查并恢复紧急停止状态"

#: src/reference/cli.md:123
msgid "`cron` — Configure and manage scheduled tasks"
msgstr "`cron` — 配置和管理定时任务"

#: src/reference/cli.md:124
msgid "`models` — Manage provider model catalogs"
msgstr "`models` — 管理提供商模型目录"

#: src/reference/cli.md:125
msgid "`providers` — List supported AI providers"
msgstr "`providers` — 列出支持的 AI 提供商"

#: src/reference/cli.md:126
msgid "`channel` — Manage channels (telegram, discord, slack)"
msgstr "`channel` — 管理频道（Telegram、Discord、Slack）"

#: src/reference/cli.md:127
msgid "`integrations` — Browse 50+ integrations"
msgstr "`integrations` — 浏览 50 多种集成"

#: src/reference/cli.md:128
msgid "`skills` — Manage skills (user-defined capabilities)"
msgstr "`skills` — 管理技能（用户定义的能力）"

#: src/reference/cli.md:129
msgid "`sop` — Manage standard operating procedures (SOPs)"
msgstr "`sop` — 管理标准操作程序（SOP）"

#: src/reference/cli.md:130
msgid "`migrate` — Migrate data from other agent runtimes"
msgstr "`migrate` — 从其他代理运行时迁移数据"

#: src/reference/cli.md:131
msgid "`auth` — Manage provider subscription authentication profiles"
msgstr "`auth` — 管理提供商订阅身份验证配置文件"

#: src/reference/cli.md:132
msgid "`hardware` — Discover and introspect USB hardware"
msgstr "`hardware` — 发现并检查 USB 硬件"

#: src/reference/cli.md:133
msgid "`peripheral` — Manage hardware peripherals (STM32, RPi GPIO, etc.)"
msgstr "`peripheral` — 管理硬件外设（STM32、RPi GPIO 等）"

#: src/reference/cli.md:134
msgid "`memory` — Manage agent memory (list, get, stats, clear)"
msgstr "`memory` — 管理代理记忆（列出、获取、统计、清除）"

#: src/reference/cli.md:135
msgid "`config` — Manage configuration"
msgstr "`config` — 管理配置"

#: src/reference/cli.md:136
msgid "`update` — Check for and apply updates"
msgstr "`update` — 检查并应用更新"

#: src/reference/cli.md:137
msgid "`self-test` — Run diagnostic self-tests"
msgstr "`self-test` — 运行诊断自检"

#: src/reference/cli.md:138
msgid "`completions` — Generate shell completion script to stdout"
msgstr "`completions` — 生成 shell 补全脚本并输出到标准输出"

#: src/reference/cli.md:139
msgid "`desktop` — Launch or install the companion desktop app"
msgstr "`desktop` — 启动或安装配套桌面应用"

