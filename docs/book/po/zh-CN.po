msgstr "示例：zeroclaw gateway get-paircode       # 显示当前配对码 zeroclaw gateway get-paircode --new # 生成新的配对码"

#: src/reference/cli.md:265
msgid "**Usage:** `zeroclaw gateway get-paircode [OPTIONS]`"
msgstr "**用法：** `zeroclaw gateway get-paircode [OPTIONS]`"

#: src/reference/cli.md:269
