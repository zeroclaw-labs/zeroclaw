msgid "ZeroClaw has two independent translation layers:"
msgstr "ZeroClaw 拥有两个独立的翻译层："

#: src/maintainers/docs-and-translations.md:5
msgid "What it covers"
msgstr "涵盖内容"

#: src/maintainers/docs-and-translations.md:7
msgid "**App strings**"
msgstr "**应用字符串**"

#: src/maintainers/docs-and-translations.md:7
msgid "Mozilla Fluent (`.ftl`)"
msgstr "Mozilla Fluent (`.ftl`)"

#: src/maintainers/docs-and-translations.md:7
msgid "CLI help text, command descriptions, runtime messages"
msgstr "CLI 帮助文本、命令描述、运行时消息"

#: src/maintainers/docs-and-translations.md:8
msgid "**Docs**"
msgstr "**文档**"

#: src/maintainers/docs-and-translations.md:8
