#: src/reference/cli.md:1630
msgid "**Arguments:**"
msgstr "**引数:**"

#: src/reference/cli.md:566
msgid "`<EXPRESSION>` — Cron expression"
msgstr "`<EXPRESSION>` — Cron式"

#: src/reference/cli.md:567 src/reference/cli.md:592 src/reference/cli.md:616
#: src/reference/cli.md:641
msgid "`<COMMAND>` — Command (shell) or prompt (agent) to run"
msgstr "`<COMMAND>` — 実行するコマンド(シェル)またはプロンプト(エージェント)"

#: src/reference/cli.md:571
msgid "`--tz <TZ>` — Optional IANA timezone (e.g. America/Los_Angeles)"
msgstr "`--tz <TZ>` — オプションのIANAタイムゾーン(例: America/Los_Angeles)"

#: src/reference/cli.md:572 src/reference/cli.md:596 src/reference/cli.md:620
#: src/reference/cli.md:645
msgid ""
"`--agent` — Treat the argument as an agent prompt instead of a shell command"
msgstr ""
"`--agent` — 引数をシェルコマンドの代わりにエージェントプロンプトとして扱う"

#: src/reference/cli.md:573 src/reference/cli.md:597 src/reference/cli.md:621
#: src/reference/cli.md:646
msgid ""
"`--allowed-tool <ALLOWED_TOOLS>` — Restrict agent cron jobs to the specified "
"tool names (repeatable, agent-only)"
msgstr ""
"`--allowed-tool <ALLOWED_TOOLS>` — エージェントcronジョブを指定されたツール名"
"に制限します(繰り返し可能、エージェントのみ)"

#: src/reference/cli.md:577
msgid "`zeroclaw cron add-at`"
msgstr "`zeroclaw cron add-at`"

#: src/reference/cli.md:579
msgid "Add a one-shot task that fires at a specific UTC timestamp."
msgstr "特定のUTCタイムスタンプで発火するワンショットタスクを追加します。"

#: src/reference/cli.md:581
msgid "The timestamp must be in RFC 3339 format (e.g. 2025-01-15T14:00:00Z)."
msgstr ""
"タイムスタンプはRFC 3339形式である必要があります(例: 2025-01-15T14:00:00Z)。"

#: src/reference/cli.md:583
msgid ""
"Examples: zeroclaw cron add-at 2025-01-15T14:00:00Z 'Send reminder' zeroclaw "
"cron add-at 2025-12-31T23:59:00Z 'Happy New Year!'"
msgstr ""
"例: zeroclaw cron add-at 2025-01-15T14:00:00Z 'Send reminder' zeroclaw cron "
"add-at 2025-12-31T23:59:00Z 'Happy New Year!'"

#: src/reference/cli.md:587
msgid "**Usage:** `zeroclaw cron add-at [OPTIONS] <AT> <COMMAND>`"
msgstr "**使用方法:** `zeroclaw cron add-at [OPTIONS] <AT> <COMMAND>`"

#: src/reference/cli.md:591
msgid "`<AT>` — One-shot timestamp in RFC3339 format"
msgstr "`<AT>` — RFC3339形式のワンショットタイムスタンプ"

#: src/reference/cli.md:601
msgid "`zeroclaw cron add-every`"
msgstr "`zeroclaw cron add-every`"

#: src/reference/cli.md:603
msgid "Add a task that repeats at a fixed interval."
msgstr "固定間隔で繰り返されるタスクを追加します。"

#: src/reference/cli.md:605
msgid "Interval is specified in milliseconds. For example, 60000 = 1 minute."
msgstr "間隔はミリ秒で指定されます。例えば、60000 = 1分です。"

#: src/reference/cli.md:607
msgid ""
"Examples: zeroclaw cron add-every 60000 'Ping heartbeat'     # every minute "
"zeroclaw cron add-every 3600000 'Hourly report'    # every hour"
msgstr ""
"例: zeroclaw cron add-every 60000 'Ping heartbeat'     # 毎分 zeroclaw cron "
"add-every 3600000 'Hourly report'    # 毎時間"

#: src/reference/cli.md:611
msgid "**Usage:** `zeroclaw cron add-every [OPTIONS] <EVERY_MS> <COMMAND>`"
msgstr "**使用方法:** `zeroclaw cron add-every [OPTIONS] <EVERY_MS> <COMMAND>`"

#: src/reference/cli.md:615
msgid "`<EVERY_MS>` — Interval in milliseconds"
msgstr "`<EVERY_MS>` — ミリ秒単位の間隔"

#: src/reference/cli.md:625
msgid "`zeroclaw cron once`"
msgstr "`zeroclaw cron once`"

#: src/reference/cli.md:627
msgid "Add a one-shot task that fires after a delay from now."
msgstr "今からの遅延後に発火するワンショットタスクを追加します。"

#: src/reference/cli.md:629
msgid ""
"Accepts human-readable durations: s (seconds), m (minutes), h (hours), d "
"(days)."
msgstr "人間が読める期間を受け入れます: s(秒)、m(分)、h(時間)、d(日)。"

#: src/reference/cli.md:631
msgid ""
"Examples: zeroclaw cron once 30m 'Run backup in 30 minutes' zeroclaw cron "
"once 2h 'Follow up on deployment' zeroclaw cron once 1d 'Daily check'"
msgstr ""
"例: zeroclaw cron once 30m 'Run backup in 30 minutes' zeroclaw cron once 2h "
"'Follow up on deployment' zeroclaw cron once 1d 'Daily check'"

#: src/reference/cli.md:636
msgid "**Usage:** `zeroclaw cron once [OPTIONS] <DELAY> <COMMAND>`"
msgstr "**使用方法:** `zeroclaw cron once [OPTIONS] <DELAY> <COMMAND>`"

#: src/reference/cli.md:640
msgid "`<DELAY>` — Delay duration"
msgstr "`<DELAY>` — 遅延期間"

#: src/reference/cli.md:650
msgid "`zeroclaw cron remove`"
msgstr "`zeroclaw cron remove`"

#: src/reference/cli.md:652
msgid "Remove a scheduled task"
msgstr "スケジュール済みタスクを削除します"

#: src/reference/cli.md:654
msgid "**Usage:** `zeroclaw cron remove <ID>`"
msgstr "**使用方法:** `zeroclaw cron remove <ID>`"

#: src/reference/cli.md:658 src/reference/cli.md:677 src/reference/cli.md:697
#: src/reference/cli.md:709
msgid "`<ID>` — Task ID"
msgstr "`<ID>` — タスクID"

#: src/reference/cli.md:662
msgid "`zeroclaw cron update`"
msgstr "`zeroclaw cron update`"

#: src/reference/cli.md:664
msgid "Update one or more fields of an existing scheduled task."
msgstr "既存のスケジュール済みタスクの1つ以上のフィールドを更新します。"

#: src/reference/cli.md:666
msgid "Only the fields you specify are changed; others remain unchanged."
msgstr "指定したフィールドのみが変更されます。その他は変わりません。"

#: src/reference/cli.md:668
msgid ""
"Examples: zeroclaw cron update TASK_ID --expression '0 8 * * \\*' zeroclaw "
"cron update TASK_ID --tz Europe/London --name 'Morning check' zeroclaw cron "
"update TASK_ID --command 'Updated message'"
msgstr ""
"例: zeroclaw cron update TASK_ID --expression '0 8 * * \\*' zeroclaw cron "
"update TASK_ID --tz Europe/London --name 'Morning check' zeroclaw cron "
"update TASK_ID --command 'Updated message'"

#: src/reference/cli.md:673
msgid "**Usage:** `zeroclaw cron update [OPTIONS] <ID>`"
msgstr "**使用方法:** `zeroclaw cron update [OPTIONS] <ID>`"

#: src/reference/cli.md:681
msgid "`--expression <EXPRESSION>` — New cron expression"
msgstr "`--expression <EXPRESSION>` — 新しいcron式"

#: src/reference/cli.md:682
msgid "`--tz <TZ>` — New IANA timezone"
msgstr "`--tz <TZ>` — 新しいIANAタイムゾーン"

#: src/reference/cli.md:683
msgid "`--command <COMMAND>` — New command to run"
msgstr "`--command <COMMAND>` — 実行する新しいコマンド"

#: src/reference/cli.md:684
msgid "`--name <NAME>` — New job name"
msgstr "`--name <NAME>` — 新しいジョブ名"

#: src/reference/cli.md:685
msgid ""
"`--allowed-tool <ALLOWED_TOOLS>` — Replace the agent job allowlist with the "
"specified tool names (repeatable)"
msgstr ""
"`--allowed-tool <ALLOWED_TOOLS>` — エージェントジョブの許可リストを指定された"
"ツール名に置き換えます(繰り返し可能)"

#: src/reference/cli.md:689
msgid "`zeroclaw cron pause`"
msgstr "`zeroclaw cron pause`"

#: src/reference/cli.md:691
msgid "Pause a scheduled task"
msgstr "スケジュール済みタスクを一時停止します"

#: src/reference/cli.md:693
msgid "**Usage:** `zeroclaw cron pause <ID>`"
msgstr "**使用方法:** `zeroclaw cron pause <ID>`"

#: src/reference/cli.md:701
msgid "`zeroclaw cron resume`"
msgstr "`zeroclaw cron resume`"

#: src/reference/cli.md:703
msgid "Resume a paused task"
msgstr "一時停止されたタスクを再開します"

#: src/reference/cli.md:705
msgid "**Usage:** `zeroclaw cron resume <ID>`"
msgstr "**使用方法:** `zeroclaw cron resume <ID>`"

#: src/reference/cli.md:713
msgid "`zeroclaw models`"
msgstr "`zeroclaw models`"

#: src/reference/cli.md:715
msgid "Manage provider model catalogs"
msgstr "プロバイダーモデルカタログを管理する"

#: src/reference/cli.md:717
msgid "**Usage:** `zeroclaw models <COMMAND>`"
msgstr "**使用方法:** `zeroclaw models <COMMAND>`"

#: src/reference/cli.md:721
msgid "`refresh` — Refresh and cache provider models"
msgstr "`refresh` — プロバイダーモデルを更新してキャッシュする"

#: src/reference/cli.md:722
msgid "`list` — List cached models for a provider"
msgstr "`list` — プロバイダーのキャッシュされたモデルをリストアップ"

#: src/reference/cli.md:723
msgid "`set` — Set the default model in config"
msgstr "`set` — 設定でデフォルトモデルを設定"

#: src/reference/cli.md:724
msgid "`status` — Show current model configuration and cache status"
msgstr "`status` — 現在のモデル設定とキャッシュステータスを表示"

#: src/reference/cli.md:728
msgid "`zeroclaw models refresh`"
msgstr "`zeroclaw models refresh`"

#: src/reference/cli.md:730
msgid "Refresh and cache provider models"
msgstr "プロバイダーモデルを更新してキャッシュする"

#: src/reference/cli.md:732
msgid "**Usage:** `zeroclaw models refresh [OPTIONS]`"
msgstr "**使用方法:** `zeroclaw models refresh [OPTIONS]`"

#: src/reference/cli.md:736 src/reference/cli.md:750
msgid ""
"`--provider <PROVIDER>` — Provider name (defaults to configured default "
"provider)"
msgstr ""
"`--provider <PROVIDER>` — プロバイダー名（設定されたデフォルトプロバイダーに"
"デフォルト設定）"

#: src/reference/cli.md:737
msgid "`--all` — Refresh all providers that support live model discovery"
msgstr "`--all` — ライブモデル検出をサポートするすべてのプロバイダーを更新"

#: src/reference/cli.md:738
msgid "`--force` — Force live refresh and ignore fresh cache"
msgstr "`--force` — ライブ更新を強制し、フレッシュキャッシュを無視"

#: src/reference/cli.md:742
msgid "`zeroclaw models list`"
msgstr "`zeroclaw models list`"

#: src/reference/cli.md:744
msgid "List cached models for a provider"
msgstr "プロバイダーのキャッシュされたモデルをリストアップ"

#: src/reference/cli.md:746
msgid "**Usage:** `zeroclaw models list [OPTIONS]`"
msgstr "**使用方法:** `zeroclaw models list [OPTIONS]`"

#: src/reference/cli.md:754
msgid "`zeroclaw models set`"
msgstr "`zeroclaw models set`"

#: src/reference/cli.md:756
msgid "Set the default model in config"
msgstr "設定でデフォルトモデルを設定"

#: src/reference/cli.md:758
msgid "**Usage:** `zeroclaw models set <MODEL>`"
msgstr "**使用方法:** `zeroclaw models set <MODEL>`"

#: src/reference/cli.md:762
msgid "`<MODEL>` — Model name to set as default"
msgstr "`<MODEL>` — デフォルトとして設定するモデル名"

#: src/reference/cli.md:766
msgid "`zeroclaw models status`"
msgstr "`zeroclaw models status`"

#: src/reference/cli.md:768
msgid "Show current model configuration and cache status"
msgstr "現在のモデル設定とキャッシュステータスを表示"

#: src/reference/cli.md:770
msgid "**Usage:** `zeroclaw models status`"
msgstr "**使用方法:** `zeroclaw models status`"

#: src/reference/cli.md:774
msgid "`zeroclaw providers`"
msgstr "`zeroclaw providers`"

#: src/reference/cli.md:776
msgid "List supported AI providers"
msgstr "サポートされているAIプロバイダーをリストアップ"

#: src/reference/cli.md:778
msgid "**Usage:** `zeroclaw providers`"
msgstr "**使用方法:** `zeroclaw providers`"

#: src/reference/cli.md:782
msgid "`zeroclaw channel`"
msgstr "`zeroclaw channel`"

#: src/reference/cli.md:784
msgid "Manage communication channels."
msgstr "通信チャネルを管理する。"

#: src/reference/cli.md:786
msgid ""
"Add, remove, list, send, and health-check channels that connect ZeroClaw to "
"messaging platforms. Supported channel types: telegram, discord, slack, "
"whatsapp, matrix, imessage, email."
msgstr ""
"ZeroClaw をメッセージングプラットフォームに接続するチャネルを追加、削除、リス"
"トアップ、送信、ヘルスチェックします。サポートされているチャネルタイプ: "
"telegram, discord, slack, whatsapp, matrix, imessage, email。"

#: src/reference/cli.md:788
msgid ""
"Examples: zeroclaw channel list zeroclaw channel doctor zeroclaw channel add "
"telegram '{\"bot_token\":\"...\",\"name\":\"my-bot\"}' zeroclaw channel "
"remove my-bot zeroclaw channel bind-telegram zeroclaw_user zeroclaw channel "
"send 'Alert!' --channel-id telegram --recipient 123456789"
msgstr ""
"例: zeroclaw channel list zeroclaw channel doctor zeroclaw channel add "
"telegram '{\"bot_token\":\"...\",\"name\":\"my-bot\"}' zeroclaw channel "
"remove my-bot zeroclaw channel bind-telegram zeroclaw_user zeroclaw channel "
"send 'Alert!' --channel-id telegram --recipient 123456789"

#: src/reference/cli.md:796
msgid "**Usage:** `zeroclaw channel <COMMAND>`"
msgstr "**使用方法:** `zeroclaw channel <COMMAND>`"

#: src/reference/cli.md:800
msgid "`list` — List all configured channels"
msgstr "`list` — 設定されたすべてのチャネルをリストアップ"

#: src/reference/cli.md:801
msgid "`start` — Start all configured channels (handled in main.rs for async)"
msgstr "`start` — 設定されたすべてのチャネルを開始（main.rs で非同期で処理）"

#: src/reference/cli.md:802
msgid ""
"`doctor` — Run health checks for configured channels (handled in main.rs for "
"async)"
msgstr ""
"`doctor` — 設定されたチャネルのヘルスチェックを実行（main.rs で非同期で処理）"

#: src/reference/cli.md:803
msgid "`add` — Add a new channel configuration"
msgstr "`add` — 新しいチャネル設定を追加"

#: src/reference/cli.md:804
msgid "`remove` — Remove a channel configuration"
msgstr "`remove` — チャネル設定を削除"

#: src/reference/cli.md:805
msgid ""
"`bind-telegram` — Bind a Telegram identity (username or numeric user ID) "
"into allowlist"
msgstr ""
"`bind-telegram` — Telegram ID（ユーザー名または数値ユーザーID）をホワイトリス"
"トにバインド"

#: src/reference/cli.md:806
msgid "`send` — Send a message to a configured channel"
msgstr "`send` — 設定されたチャネルにメッセージを送信"

#: src/reference/cli.md:810
msgid "`zeroclaw channel list`"
msgstr "`zeroclaw channel list`"

#: src/reference/cli.md:812
msgid "List all configured channels"
msgstr "設定されたすべてのチャネルをリストアップ"

#: src/reference/cli.md:814
msgid "**Usage:** `zeroclaw channel list`"
msgstr "**使用方法:** `zeroclaw channel list`"

#: src/reference/cli.md:818
msgid "`zeroclaw channel start`"
msgstr "`zeroclaw channel start`"

#: src/reference/cli.md:820
msgid "Start all configured channels (handled in main.rs for async)"
msgstr "設定されたすべてのチャネルを開始（main.rs で非同期で処理）"

#: src/reference/cli.md:822
msgid "**Usage:** `zeroclaw channel start`"
msgstr "**使用方法:** `zeroclaw channel start`"

#: src/reference/cli.md:826
msgid "`zeroclaw channel doctor`"
msgstr "`zeroclaw channel doctor`"

#: src/reference/cli.md:828
msgid ""
"Run health checks for configured channels (handled in main.rs for async)"
msgstr "設定されたチャネルのヘルスチェックを実行（main.rs で非同期で処理）"

#: src/reference/cli.md:830
msgid "**Usage:** `zeroclaw channel doctor`"
msgstr "**使用方法:** `zeroclaw channel doctor`"

#: src/reference/cli.md:834
msgid "`zeroclaw channel add`"
msgstr "`zeroclaw channel add`"

#: src/reference/cli.md:836
msgid "Add a new channel configuration."
msgstr "新しいチャネル設定を追加する。"

#: src/reference/cli.md:838
msgid ""
"Provide the channel type and a JSON object with the required configuration "
"keys for that channel type."
msgstr ""
"チャネルタイプとそのチャネルタイプに必要な設定キーを含むJSONオブジェクトを提"
"供します。"

#: src/reference/cli.md:840
msgid ""
"Supported types: telegram, discord, slack, whatsapp, matrix, imessage, email."
msgstr ""
"サポートされているタイプ: telegram、discord、slack、whatsapp、matrix、"
"imessage、email。"

#: src/reference/cli.md:842
msgid ""
"Examples: zeroclaw channel add telegram '{\"bot_token\":\"...\",\"name\":"
"\"my-bot\"}' zeroclaw channel add discord '{\"bot_token\":\"...\",\"name\":"
"\"my-discord\"}'"
msgstr ""
"例: zeroclaw channel add telegram '{\"bot_token\":\"...\",\"name\":\"my-"
"bot\"}' zeroclaw channel add discord '{\"bot_token\":\"...\",\"name\":\"my-"
"discord\"}'"

#: src/reference/cli.md:846
msgid "**Usage:** `zeroclaw channel add <CHANNEL_TYPE> <CONFIG>`"
msgstr "**使用方法:** `zeroclaw channel add <CHANNEL_TYPE> <CONFIG>`"

#: src/reference/cli.md:850
msgid ""
"`<CHANNEL_TYPE>` — Channel type (telegram, discord, slack, whatsapp, matrix, "
"imessage, email)"
msgstr ""
"`<CHANNEL_TYPE>` — チャネルタイプ (telegram、discord、slack、whatsapp、"
"matrix、imessage、email)"

#: src/reference/cli.md:851
msgid "`<CONFIG>` — Optional configuration as JSON"
msgstr "`<CONFIG>` — JSONとしてのオプション設定"

#: src/reference/cli.md:855
msgid "`zeroclaw channel remove`"
msgstr "`zeroclaw channel remove`"

#: src/reference/cli.md:857
msgid "Remove a channel configuration"
msgstr "チャネル設定を削除します"

#: src/reference/cli.md:859
msgid "**Usage:** `zeroclaw channel remove <NAME>`"
msgstr "**使用方法:** `zeroclaw channel remove <NAME>`"

#: src/reference/cli.md:863
msgid "`<NAME>` — Channel name to remove"
msgstr "`<NAME>` — 削除するチャネル名"

#: src/reference/cli.md:867
msgid "`zeroclaw channel bind-telegram`"
msgstr "`zeroclaw channel bind-telegram`"

#: src/reference/cli.md:869
msgid "Bind a Telegram identity into the allowlist."
msgstr "Telegramアイデンティティを許可リストにバインドします。"

#: src/reference/cli.md:871
msgid ""
"Adds a Telegram username (without the '@' prefix) or numeric user ID to the "
"channel allowlist so the agent will respond to messages from that identity."
msgstr ""
"Telegramユーザー名 ('@'プレフィックスなし) または数値ユーザーIDをチャネル許可"
"リストに追加して、エージェントがそのアイデンティティからのメッセージに応答す"
"るようにします。"

#: src/reference/cli.md:873
msgid ""
"Examples: zeroclaw channel bind-telegram zeroclaw_user zeroclaw channel bind-"
"telegram 123456789"
msgstr ""
"例: zeroclaw channel bind-telegram zeroclaw_user zeroclaw channel bind-"
"telegram 123456789"

#: src/reference/cli.md:877
msgid "**Usage:** `zeroclaw channel bind-telegram <IDENTITY>`"
msgstr "**使用方法:** `zeroclaw channel bind-telegram <IDENTITY>`"

#: src/reference/cli.md:881
msgid ""
"`<IDENTITY>` — Telegram identity to allow (username without '@' or numeric "
"user ID)"
msgstr ""
"`<IDENTITY>` — 許可するTelegramアイデンティティ ('@'なしのユーザー名または数"
"値ユーザーID)"

#: src/reference/cli.md:885
msgid "`zeroclaw channel send`"
msgstr "`zeroclaw channel send`"

#: src/reference/cli.md:887
msgid "Send a one-off message to a configured channel."
msgstr "設定されたチャネルに1回限りのメッセージを送信します。"

#: src/reference/cli.md:889
msgid ""
"Sends a text message through the specified channel without starting the full "
"agent loop. Useful for scripted notifications, hardware sensor alerts, and "
"automation pipelines."
msgstr ""
"フルエージェントループを開始せずに、指定されたチャネルを通じてテキストメッ"
"セージを送信します。スクリプト化された通知、ハードウェアセンサーアラート、自"
"動化パイプラインに役立ちます。"

#: src/reference/cli.md:891
msgid ""
"The --channel-id selects the channel by its config section name (e.g. "
"'telegram', 'discord', 'slack'). The --recipient is the platform-specific "
"destination (e.g. a Telegram chat ID)."
msgstr ""
"--channel-idは設定セクション名 (例: 'telegram'、'discord'、'slack') でチャネ"
"ルを選択します。--recipientはプラットフォーム固有の宛先 (例: Telegramチャット"
"ID) です。"

#: src/reference/cli.md:893
msgid ""
"Examples: zeroclaw channel send 'Someone is near your device.' --channel-id "
"telegram --recipient 123456789 zeroclaw channel send 'Build succeeded!' --"
"channel-id discord --recipient 987654321"
msgstr ""
"例: zeroclaw channel send 'Someone is near your device.' --channel-id "
"telegram --recipient 123456789 zeroclaw channel send 'Build succeeded!' --"
"channel-id discord --recipient 987654321"

#: src/reference/cli.md:897
msgid ""
"**Usage:** `zeroclaw channel send --channel-id <CHANNEL_ID> --recipient "
"<RECIPIENT> <MESSAGE>`"
msgstr ""
"**使用方法:** `zeroclaw channel send --channel-id <CHANNEL_ID> --recipient "
"<RECIPIENT> <MESSAGE>`"

#: src/reference/cli.md:901
msgid "`<MESSAGE>` — Message text to send"
msgstr "`<MESSAGE>` — 送信するメッセージテキスト"

#: src/reference/cli.md:905
msgid ""
"`--channel-id <CHANNEL_ID>` — Channel config name (e.g. telegram, discord, "
"slack)"
msgstr ""
"`--channel-id <CHANNEL_ID>` — チャネル設定名 (例: telegram、discord、slack)"

#: src/reference/cli.md:906
msgid ""
"`--recipient <RECIPIENT>` — Recipient identifier (platform-specific, e.g. "
"Telegram chat ID)"
msgstr ""
"`--recipient <RECIPIENT>` — 受信者識別子 (プラットフォーム固有、例: Telegram"
"チャットID)"

#: src/reference/cli.md:910
msgid "`zeroclaw integrations`"
msgstr "`zeroclaw integrations`"

#: src/reference/cli.md:912
msgid "Browse 50+ integrations"
msgstr "50以上のインテグレーションを参照します"

#: src/reference/cli.md:914
msgid "**Usage:** `zeroclaw integrations <COMMAND>`"
msgstr "**使用方法:** `zeroclaw integrations <COMMAND>`"

#: src/reference/cli.md:918
msgid "`info` — Show details about a specific integration"
msgstr "`info` — 特定のインテグレーションの詳細を表示"

#: src/reference/cli.md:922
msgid "`zeroclaw integrations info`"
msgstr "`zeroclaw integrations info`"

#: src/reference/cli.md:924
msgid "Show details about a specific integration"
msgstr "特定のインテグレーションの詳細を表示します"

#: src/reference/cli.md:926
msgid "**Usage:** `zeroclaw integrations info <NAME>`"
