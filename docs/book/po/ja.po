msgstr "`SOP.md`:"

#: src/reference/sop/cookbook.md:35
msgid "2. IoT Alert Handler (MQTT)"
msgstr "2. IoT アラートハンドラー (MQTT)"

#: src/reference/sop/cookbook.md:39
msgid ""
"```toml\n"
"[sop]\n"
"name = \"high-temp-alert\"\n"
"description = \"Handle high temperature telemetry alerts\"\n"
"version = \"1.0.0\"\n"
"priority = \"critical\"\n"
"execution_mode = \"priority_based\"\n"
"\n"
"[[triggers]]\n"
"type = \"mqtt\"\n"
"topic = \"sensors/temp/alert\"\n"
"condition = \"$.temperature_c >= 85\"\n"
"```"
msgstr ""
"```toml\n"
"[sop]\n"
"name = \"high-temp-alert\"\n"
"description = \"Handle high temperature telemetry alerts\"\n"
"version = \"1.0.0\"\n"
"priority = \"critical\"\n"
"execution_mode = \"priority_based\"\n"
"\n"
"[[triggers]]\n"
"type = \"mqtt\"\n"
"topic = \"sensors/temp/alert\"\n"
"condition = \"$.temperature_c >= 85\"\n"
"```"

#: src/reference/sop/cookbook.md:65
msgid "3. Daily Digest (Cron)"
msgstr "3. 日次ダイジェスト (Cron)"

#: src/reference/sop/cookbook.md:69
msgid ""
"```toml\n"
"[sop]\n"
"name = \"daily-summary\"\n"
"description = \"Generate daily operational summary\"\n"
"version = \"1.0.0\"\n"
"priority = \"normal\"\n"
"execution_mode = \"supervised\"\n"
"\n"
"[[triggers]]\n"
"type = \"cron\"\n"
"expression = \"0 9 * * *\"\n"
"```"
msgstr ""
"```toml\n"
"[sop]\n"
"name = \"daily-summary\"\n"
"description = \"Generate daily operational summary\"\n"
"version = \"1.0.0\"\n"
"priority = \"normal\"\n"
"execution_mode = \"supervised\"\n"
"\n"
"[[triggers]]\n"
