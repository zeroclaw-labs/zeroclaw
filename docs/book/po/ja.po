#: src/reference/sop/cookbook.md:3
msgid ""
"Practical SOP templates in the runtime-supported `SOP.toml` + `SOP.md` "
"format."
msgstr ""

#: src/reference/sop/cookbook.md:5
msgid "1. Human-in-the-Loop Deployment"
msgstr ""

#: src/reference/sop/cookbook.md:7 src/reference/sop/cookbook.md:37
#: src/reference/sop/cookbook.md:67
msgid "`SOP.toml`:"
msgstr ""

#: src/reference/sop/cookbook.md:9
msgid ""
"```toml\n"
"[sop]\n"
"name = \"deploy-prod\"\n"
"description = \"Manual deployment with explicit approval gate\"\n"
"version = \"1.0.0\"\n"
"priority = \"high\"\n"
"execution_mode = \"supervised\"\n"
"max_concurrent = 1\n"
"\n"
"[[triggers]]\n"
"type = \"manual\"\n"
"```"
msgstr ""

#: src/reference/sop/cookbook.md:22 src/reference/sop/cookbook.md:53
#: src/reference/sop/cookbook.md:82
msgid "`SOP.md`:"
msgstr ""

#: src/reference/sop/cookbook.md:35
msgid "2. IoT Alert Handler (MQTT)"
msgstr ""

#: src/reference/sop/cookbook.md:39
msgid ""
"```toml\n"
"[sop]\n"
"name = \"high-temp-alert\"\n"
"description = \"Handle high temperature telemetry alerts\"\n"
"version = \"1.0.0\"\n"
"priority = \"critical\"\n"
"execution_mode = \"priority_based\"\n"
"\n"
"[[triggers]]\n"
"type = \"mqtt\"\n"
"topic = \"sensors/temp/alert\"\n"
"condition = \"$.temperature_c >= 85\"\n"
"```"
msgstr ""

#: src/reference/sop/cookbook.md:65
msgid "3. Daily Digest (Cron)"
msgstr ""

#: src/reference/sop/cookbook.md:69
msgid ""
"```toml\n"
"[sop]\n"
"name = \"daily-summary\"\n"
"description = \"Generate daily operational summary\"\n"
"version = \"1.0.0\"\n"
"priority = \"normal\"\n"
"execution_mode = \"supervised\"\n"
"\n"
"[[triggers]]\n"
"type = \"cron\"\n"
"expression = \"0 9 * * *\"\n"
"```"
msgstr ""

#: src/reference/sop/syntax.md:1
msgid "SOP Syntax Reference"
msgstr ""

#: src/reference/sop/syntax.md:3
msgid ""
"SOP definitions are loaded from subdirectories under `sops_dir` (default: "
"`<workspace>/sops`)."
msgstr ""

#: src/reference/sop/syntax.md:5
msgid "1. Directory Layout"
msgstr ""

#: src/reference/sop/syntax.md:14
msgid ""
"Each SOP must have `SOP.toml`. `SOP.md` is optional, but runs with no parsed "
"steps will fail validation."
msgstr ""

#: src/reference/sop/syntax.md:16
msgid "2. `SOP.toml`"
msgstr ""

#: src/reference/sop/syntax.md:18
msgid ""
"```toml\n"
"[sop]\n"
"name = \"deploy-prod\"\n"
"description = \"Deploy service to production\"\n"
"version = \"1.0.0\"\n"
"priority = \"high\"              # low | normal | high | critical\n"
"execution_mode = \"supervised\"  # auto | supervised | step_by_step | "
"priority_based\n"
"cooldown_secs = 300\n"
"max_concurrent = 1\n"
"\n"
"[[triggers]]\n"
"type = \"webhook\"\n"
"path = \"/sop/deploy\"\n"
"\n"
"[[triggers]]\n"
"type = \"manual\"\n"
"\n"
"[[triggers]]\n"
"type = \"mqtt\"\n"
"topic = \"ops/deploy\"\n"
"condition = \"$.env == \\\"prod\\\"\"\n"
"```"
msgstr ""

