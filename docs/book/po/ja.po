msgstr ""

#: src/security/tool-receipts.md:46
msgid "Unverifiable"
msgstr ""

#: src/security/tool-receipts.md:46
msgid "Receipts in log prove execution"
msgstr ""

#: src/security/tool-receipts.md:47
