msgid ""
"```toml\n"
"[[triggers]]\n"
"type = \"cron\"\n"
"expression = \"0 0 8 * * *\"\n"
"```"
msgstr ""
"```toml\n"
"[[triggers]]\n"
"type = \"cron\"\n"
"expression = \"0 0 8 * * *\"\n"
"```"

#: src/reference/sop/connectivity.md:112
