msgid "Trigger example:"
msgstr "トリガーの例:"

#: src/sop/connectivity.md:106
msgid ""
"```toml\n"
"[[triggers]]\n"
"type = \"cron\"\n"
"expression = \"0 0 8 * * *\"\n"
"```"
msgstr ""
"```toml\n"
"[[triggers]]\n"
"type = \"cron\"\n"
"expression = \"0 0 8 * * *\"\n"
"```"

