#: src/developing/plugin-protocol.md:15
msgid "Plugin structure"
msgstr "Estructura del complemento"

#: src/developing/plugin-protocol.md:17
msgid "A plugin is a directory containing:"
msgstr "Un plugin es un directorio que contiene:"

#: src/developing/plugin-protocol.md:25
msgid ""
"Plugins are discovered from `~/.zeroclaw/plugins/` (configurable via "
