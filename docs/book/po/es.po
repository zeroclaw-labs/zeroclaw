msgid ""
"Examples: zeroclaw channel add telegram '{\"bot_token\":\"...\",\"name\":"
"\"my-bot\"}' zeroclaw channel add discord '{\"bot_token\":\"...\",\"name\":"
"\"my-discord\"}'"
msgstr "Ejemplos: zeroclaw channel add telegram '{\"bot_token\":\"...\",\"name\":\"my-bot\"}' zeroclaw channel add discord '{\"bot_token\":\"...\",\"name\":\"my-discord\"}'"

