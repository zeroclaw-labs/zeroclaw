msgstr "`zeroclaw peripheral flash-nucleo`"

#: src/reference/cli.md:1383
msgid "Flash ZeroClaw firmware to Nucleo-F401RE (builds + probe-rs run)"
msgstr "Flash ZeroClaw firmware to Nucleo-F401RE (builds + probe-rs run)"

#: src/reference/cli.md:1385
msgid "**Usage:** `zeroclaw peripheral flash-nucleo`"
msgstr "**Uso:** `zeroclaw peripheral flash-nucleo`"

#: src/reference/cli.md:1389
msgid "`zeroclaw memory`"
msgstr "`zeroclaw memory`"

#: src/reference/cli.md:1391
msgid "Manage agent memory entries."
msgstr "Gestionar las entradas de memoria del agente."

#: src/reference/cli.md:1393
msgid ""
"List, inspect, and clear memory entries stored by the agent. Supports "
"filtering by category and session, pagination, and batch clearing with "
"confirmation."
msgstr "Listar, inspeccionar y limpiar las entradas de memoria almacenadas por el agente. Admite filtrado por categoría y sesión, paginación y borrado por lotes con confirmación."

#: src/reference/cli.md:1395
msgid ""
"Examples: zeroclaw memory stats zeroclaw memory list zeroclaw memory list --"
"category core --limit 10 zeroclaw memory get KEY zeroclaw memory clear --"
"category conversation --yes"
msgstr "Ejemplos: zeroclaw memory stats zeroclaw memory list zeroclaw memory list --category core --limit 10 zeroclaw memory get KEY zeroclaw memory clear --category conversation --yes"

