msgid ""
"Provide the channel type and a JSON object with the required configuration "
"keys for that channel type."
msgstr "Proporciona el tipo de canal y un objeto JSON con las claves de configuración requeridas para ese tipo de canal."

#: src/reference/cli.md:840
msgid ""
"Supported types: telegram, discord, slack, whatsapp, matrix, imessage, email."
msgstr "Tipos compatibles: telegram, discord, slack, whatsapp, matrix, imessage, email."

