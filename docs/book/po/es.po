#: src/reference/cli.md:461
msgid "`zeroclaw estop`"
msgstr "`zeroclaw estop`"

#: src/reference/cli.md:463
msgid "Engage, inspect, and resume emergency-stop states."
msgstr "Activar, inspeccionar y reanudar los estados de parada de emergencia."

#: src/reference/cli.md:465
msgid ""
"Examples: - `zeroclaw estop` - `zeroclaw estop --level network-kill` - "
"`zeroclaw estop --level domain-block --domain \"*.chase.com\"` - `zeroclaw "
"estop --level tool-freeze --tool shell --tool browser` - `zeroclaw estop "
"status` - `zeroclaw estop resume --network` - `zeroclaw estop resume --"
"domain \"*.chase.com\"` - `zeroclaw estop resume --tool shell`"
msgstr "Ejemplos: - `zeroclaw estop` - `zeroclaw estop --level network-kill` - `zeroclaw estop --level domain-block --domain \"*.chase.com\"` - `zeroclaw estop --level tool-freeze --tool shell --tool browser` - `zeroclaw estop status` - `zeroclaw estop resume --network` - `zeroclaw estop resume --domain \"*.chase.com\"` - `zeroclaw estop resume --tool shell`"

#: src/reference/cli.md:467
msgid "**Usage:** `zeroclaw estop [OPTIONS] [COMMAND]`"
msgstr "**Uso:** `zeroclaw estop [OPCIONES] [COMANDO]`"

#: src/reference/cli.md:471
msgid "`status` — Print current estop status"
msgstr "`status` — Imprime el estado actual del estop"

