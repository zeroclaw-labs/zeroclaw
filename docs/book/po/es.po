"model = \"<model-id>\"       # required — passed to the provider\n"
"```"
msgstr "```toml\n[providers.models.<name>]\nkind = \"<provider-kind>\"   # obligatorio — selecciona la implementación\nmodel = \"<model-id>\"       # obligatorio — se pasa al proveedor\n```"

