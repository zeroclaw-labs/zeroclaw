msgid "Service / runtime labels"
msgstr "Etiquetas de servicio / tiempo de ejecución"

#: src/contributing/privacy.md:25
msgid "`zeroclaw_bot`, `zeroclaw_service`, `zeroclaw_runtime`, `zeroclaw_node`"
msgstr "`zeroclaw_bot`, `zeroclaw_service`, `zeroclaw_runtime`, `zeroclaw_node`"

