msgid "`default` — a sensible core build"
msgstr "`default` — una compilación central sensata"

#: src/architecture/crates.md:131
msgid "`ci-all` — everything on, for CI"
msgstr "`ci-all` — todo activado, para CI"

#: src/architecture/crates.md:132
msgid ""
"`channel-<name>` — opt-in per channel (e.g. `channel-matrix`, `channel-"
"discord`)"
msgstr "`channel-<nombre>` — opt-in por canal (por ejemplo, `channel-matrix`, `channel-discord`)"

