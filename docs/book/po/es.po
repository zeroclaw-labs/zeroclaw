msgid "2. MQTT Integration"
msgstr ""

#: src/reference/sop/connectivity.md:25
msgid "2.1 Configuration"
msgstr ""

#: src/reference/sop/connectivity.md:27
msgid ""
"Configure broker access under `[channels_config.mqtt]` in `config.toml` — "
"see the [Config reference](../config.md). The `use_tls` flag must match the "
"scheme of `broker_url` (`mqtts://` ⇒ `true`, `mqtt://` ⇒ `false`)."
msgstr ""

