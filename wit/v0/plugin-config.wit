package zeroclaw:plugin@0.1.0;

/// Per-instance network configuration the host resolves at
/// plugin-instantiation time. Shared by tool, memory, and channel plugins.
@unstable(feature = plugins-wit-v0)
interface plugin-config {
    /// The proxy URL applied to this plugin instance's outbound networking
    /// (`wasi:http` and, for channel plugins, `websocket`), if any. This is
    /// informational — the host already applies the proxy to every outbound
    /// call; plugins do not need to do anything with this value themselves
    /// unless they want to report it (e.g. in diagnostics).
    get-proxy-url: func() -> option<string>;
}
