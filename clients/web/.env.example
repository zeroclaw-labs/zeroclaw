# Gateway server URL (the ZeroClaw backend)
# For local development, point to your local gateway:
NEXT_PUBLIC_DEFAULT_SERVER_URL=http://localhost:8080

# R2 base URL for static assets (optional)
# NEXT_PUBLIC_R2_BASE_URL=

# Kakao OAuth REST API key (client-side, for Kakao login button)
# Only needed if Kakao login is enabled. Get from Kakao Developer Console.
# NEXT_PUBLIC_KAKAO_REST_API_KEY=

# --- Server-side only (Railway / backend) ---
# KAKAO_ADMIN_KEY=        # Set in Railway dashboard only
# KAKAO_REST_API_KEY=     # Set in Railway dashboard only
